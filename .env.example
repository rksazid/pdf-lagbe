PORT=3000
NODE_ENV=development

# PDF Generation
PDF_TIMEOUT=10000
MAX_HTML_SIZE=2097152
DEFAULT_FORMAT=A4

# Browser
MAX_CONCURRENT_PAGES=3

# Rate Limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=10

# Security
JS_EXECUTION_TIMEOUT=5000

# Render.com (set automatically on Render)
# RENDER=true
# PUPPETEER_CACHE_DIR=/opt/render/.cache/puppeteer
